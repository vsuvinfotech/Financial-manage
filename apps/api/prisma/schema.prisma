generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores     Store[]
  users      User[]
  roles      Role[]
  categories Category[]

  @@map("companies")
}

model Store {
  id        String   @id @default(cuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userAccess    UserStoreAccess[]
  revenues      Revenue[]
  expenses      Expense[]
  purchases     Purchase[]
  taxes         Tax[]
  dailyClosings DailyClosing[]

  @@unique([name, companyId])
  @@index([companyId])
  @@map("stores")
}

model UserStoreAccess {
  id      String @id @default(cuid())
  userId  String
  storeId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([userId])
  @@map("user_store_access")
}

model Role {
  id          String   @id @default(cuid())
  name        String
  permissions String[]
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]

  @@unique([name, companyId])
  @@index([companyId])
  @@map("roles")
}

enum PaymentMethod {
  CASH
  CARD
}

enum CategoryType {
  REVENUE
  EXPENSE
}

model Category {
  id        String       @id @default(cuid())
  name      String
  type      CategoryType
  isActive  Boolean      @default(true)
  companyId String
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([name, type, companyId])
  @@index([type])
  @@index([companyId])
  @@map("categories")
}

model User {
  id          String            @id @default(cuid())
  name        String
  email       String
  password    String
  roleId      String
  role        Role              @relation(fields: [roleId], references: [id])
  companyId   String?
  company     Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  storeAccess UserStoreAccess[]
  updatedAt   DateTime          @updatedAt
  createdAt   DateTime          @default(now())
  revenues    Revenue[]
  expenses    Expense[]
  purchases   Purchase[]
  taxes       Tax[]

  @@unique([email, companyId])
  @@index([companyId])
  @@map("users")
}

model Revenue {
  id            String          @id @default(cuid())
  category      String
  amount        Decimal         @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  notes         String?
  date          DateTime
  storeId       String
  companyId     String
  store         Store           @relation(fields: [storeId], references: [id])
  createdBy     String
  createdAt     DateTime        @default(now())
  creator       User            @relation(fields: [createdBy], references: [id])

  @@index([date])
  @@index([companyId, date])
  @@index([storeId, date])
  @@map("revenues")
}

model Expense {
  id            String        @id @default(cuid())
  expenseType   String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  notes         String?
  date          DateTime
  storeId       String
  companyId     String
  store         Store         @relation(fields: [storeId], references: [id])
  createdBy     String
  createdAt     DateTime      @default(now())
  creator       User          @relation(fields: [createdBy], references: [id])

  @@index([date])
  @@index([companyId, date])
  @@index([storeId, date])
  @@map("expenses")
}

model Purchase {
  id            String        @id @default(cuid())
  vendorName    String
  category      String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  notes         String?
  date          DateTime
  storeId       String
  companyId     String
  store         Store         @relation(fields: [storeId], references: [id])
  createdBy     String
  createdAt     DateTime      @default(now())
  creator       User          @relation(fields: [createdBy], references: [id])

  @@index([date])
  @@index([companyId, date])
  @@index([storeId, date])
  @@map("purchases")
}

model Tax {
  id            String        @id @default(cuid())
  taxType       String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  notes         String?
  date          DateTime
  storeId       String
  companyId     String
  store         Store         @relation(fields: [storeId], references: [id])
  createdBy     String
  createdAt     DateTime      @default(now())
  creator       User          @relation(fields: [createdBy], references: [id])

  @@index([date])
  @@index([companyId, date])
  @@index([storeId, date])
  @@map("taxes")
}

model DailyClosing {
  id             String   @id @default(cuid())
  date           DateTime
  storeId        String
  companyId      String
  store          Store    @relation(fields: [storeId], references: [id])
  totalRevenue   Decimal  @db.Decimal(12, 2)
  totalExpense   Decimal  @db.Decimal(12, 2)
  totalPurchase  Decimal  @db.Decimal(12, 2)
  totalTax       Decimal  @db.Decimal(12, 2)
  cashTotal      Decimal  @db.Decimal(12, 2)
  cardTotal      Decimal  @db.Decimal(12, 2)
  netProfit      Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())

  @@unique([storeId, date])
  @@index([companyId, date])
  @@map("daily_closing")
}
